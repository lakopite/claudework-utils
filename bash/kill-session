#!/bin/bash

# kill-session: Gracefully shut down all agents, bastions, and rotator, then kill session
# Usage: kill-session

if ! tmux has-session -t claude-work 2>/dev/null; then
  echo "No claude-work session found"
  exit 0
fi

# Kill all orchestrator windows (no graceful shutdown needed — just bash scripts)
orchestrators=$(tmux list-windows -t claude-work -F '#W' 2>/dev/null | grep -E '^orch-' || true)
if [ -n "$orchestrators" ]; then
  for orch in $orchestrators; do
    echo "Killing orchestrator $orch..."
    tmux kill-window -t "claude-work:$orch" 2>/dev/null
  done
else
  echo "No orchestrator windows found"
fi

# Collect all agent windows
agents=$(tmux list-windows -t claude-work -F '#W' 2>/dev/null | grep -E '^agent-[0-9]+$')

# Send /exit to all agents
if [ -n "$agents" ]; then
  for agent in $agents; do
    echo "Sending /exit to $agent..."
    tmux send-keys -t "claude-work:$agent" "/exit" Enter
    sleep 2
    tmux send-keys -t "claude-work:$agent" "" Enter
  done
else
  echo "No agent windows found"
fi

# Send /exit to bastion-retiring if it exists
if tmux list-windows -t claude-work -F '#W' 2>/dev/null | grep -q "^bastion-retiring$"; then
  echo "Sending /exit to bastion-retiring..."
  tmux send-keys -t "claude-work:bastion-retiring" "/exit" Enter
  sleep 2
  tmux send-keys -t "claude-work:bastion-retiring" "" Enter
fi

# Send /exit to bastion if it exists
if tmux list-windows -t claude-work -F '#W' 2>/dev/null | grep -q "^bastion$"; then
  echo "Sending /exit to bastion..."
  tmux send-keys -t "claude-work:bastion" "/exit" Enter
  sleep 2
  tmux send-keys -t "claude-work:bastion" "" Enter
fi

echo "Waiting for graceful shutdown..."
sleep 3

echo "Killing claude-work session..."
tmux kill-session -t claude-work 2>/dev/null

echo "Done: claude-work session killed"
