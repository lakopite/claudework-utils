# --- API Configuration ---
# OpenRouter API key (required)
ANTHROPIC_API_KEY=sk-or-v1-your-key-here

# OpenRouter endpoint
ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1

# Avoid Anthropic-specific beta header errors with third-party providers
CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1

# Optional: override the default model
# ANTHROPIC_MODEL=anthropic/claude-sonnet-4-6

# --- Host Paths ---
# Override defaults from docker-compose.yml if your paths differ.
# CLAUDE_HOME=~/claude-home
# SSH_KEY_PATH=~/.ssh/claude_docker_id_ed25519
# SSH_PUB_PATH=~/.ssh/claude_docker_id_ed25519.pub
